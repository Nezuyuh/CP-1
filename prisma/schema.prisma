generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Tour {
  id             String         @id @default(cuid())
  image          String?
  tourTitle      String
  destinations   String
  duration       String
  pricePerPerson Decimal?       @db.Decimal(10, 2)
  currency       String         @default("USD")
  priceNotes     String?
  airline        String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  travelDates    TravelDate[]
  flights        Flight[]
  itinerary      ItineraryDay[]
  bookings       Booking[]
}

model TravelDate {
  id        String    @id @default(cuid())
  tourId    String
  dateLabel String
  tour      Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings  Booking[]
}

model Flight {
  id          String @id @default(cuid())
  tourId      String
  flightCode  String
  origin      String
  destination String
  departTime  String
  arrivalTime String
  flightOrder Int    @default(0)
  tour        Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
}

model ItineraryDay {
  id            String     @id @default(cuid())
  tourId        String
  day           String
  title         String
  accommodation String?
  dayOrder      Int        @default(0)
  tour          Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  activities    Activity[]
}

model Activity {
  id             String       @id @default(cuid())
  itineraryDayId String
  description    String
  activityOrder  Int          @default(0)
  itineraryDay   ItineraryDay @relation(fields: [itineraryDayId], references: [id], onDelete: Cascade)
}

model Booking {
  id              String            @id @default(cuid())
  userId          String
  tourId          String
  travelDateId    String
  paxCount        Int               @default(1)
  roomType        String?
  totalPrice      Decimal?          @db.Decimal(10, 2)
  status          BookingStatus     @default(PENDING)
  notes           String?
  isOnsiteBooking Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id])
  tour            Tour              @relation(fields: [tourId], references: [id])
  travelDate      TravelDate        @relation(fields: [travelDateId], references: [id])
  documents       BookingDocument[]
}

model BookingDocument {
  id         String   @id @default(cuid())
  bookingId  String
  fileName   String
  fileUrl    String
  fileType   String?
  fileSize   Int?
  uploadedAt DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
